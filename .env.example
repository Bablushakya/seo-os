# ============================================================
# SEO-OS — Environment Variables Template
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to Git.
#
# From DOC3 Section 7.3 — Credential Management
# ============================================================

# ---- Supabase (Public — safe to expose in browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ---- Supabase (Secret — NEVER expose to browser) ----
# Used ONLY in server-side admin operations (audit log, n8n webhooks)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ---- Gemini AI ----
# Used ONLY server-side in /api/ai/* routes
# NEVER expose to the browser bundle
GEMINI_API_KEY=your-gemini-api-key-here

# ---- n8n Webhook Security ----
# Secret token that n8n sends in Authorization header
# Your API route validates this before processing n8n triggers
N8N_WEBHOOK_SECRET=generate-a-random-64-char-string-here

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- How to find these values: ----
# SUPABASE_URL + ANON_KEY: Supabase Dashboard → Settings → API
# SERVICE_ROLE_KEY: Supabase Dashboard → Settings → API (keep secret!)
# GEMINI_API_KEY: https://aistudio.google.com/app/apikey
# N8N_WEBHOOK_SECRET: Generate with: openssl rand -hex 32
